{
  "name": "mcp-gorgias",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP server for Gorgias API integration",
  "main": "src/index.js",
  "bin": {
    "mcp-gorgias": "src/index.js"
  },
  "scripts": {
    "start": "node src/http-server.js",
    "start:stdio": "node src/index.js",
    "dev": "node --watch src/http-server.js",
    "dev:stdio": "node --watch src/index.js",
    "inspect": "npx -y @modelcontextprotocol/inspector node src/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "zod": "^3.22.4"
  }
}
